{
  "name": "civicsync",
  "version": "1.0.0",
  "description": "CivicSync monorepo — frontend + backend",
  "private": true,
  "scripts": {
    "frontend": "npm run dev --prefix frontend",
    "backend": "npm run dev --prefix backend",
    "dev": "concurrently -n FRONTEND,BACKEND -c cyan,yellow \"npm run frontend\" \"npm run backend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "firebase": "^12.10.0"
  }
}
